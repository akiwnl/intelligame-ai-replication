# Modelo das chaves de API usadas por ai-experiment/scripts/run_models.py.
#
# Uso (Docker):   cp .env.example .env  &&  editar  →  docker compose run usa --env-file .env
# Uso (local):    prefira ai-experiment/scripts/env.sh.example (source scripts/env.sh)
#
# ATENCAO: .env contem segredos e esta no .gitignore — NAO versione nem compartilhe.
# Cada *_API_KEY aceita varias chaves separadas por virgula (rodizio quando uma estoura a cota).

GEMINI_API_KEY=SUA_CHAVE_GEMINI_AQUI
OPENROUTER_API_KEY=SUA_CHAVE_OPENROUTER_AQUI
GROQ_API_KEY=SUA_CHAVE_GROQ_AQUI

# Overrides opcionais por modelo (base_url / model / key). Ex.: rodar o ai-3 no Groq:
#   AI3_BASE_URL=https://api.groq.com/openai/v1
#   AI3_MODEL=llama-3.3-70b-versatile
#   AI3_API_KEY=SUA_CHAVE_GROQ_AQUI
# Fuso fixo para determinismo do scoring (ja default no Dockerfile):
# TZ=UTC
