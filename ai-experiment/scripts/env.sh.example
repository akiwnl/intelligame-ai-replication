# Modelo de configuração das chaves de API usadas por run_models.py.
# Copie para env.sh e preencha com suas chaves:   cp env.sh.example env.sh
# Uso:  source scripts/env.sh
#
# ATENÇÃO: env.sh contém segredos e está no .gitignore — NÃO versione nem compartilhe.
# Várias chaves do mesmo modelo: separe por vírgula -> o runner faz rodízio quando uma estoura a cota.

export GEMINI_API_KEY='SUA_CHAVE_GEMINI_AQUI'              # ai-1 Gemini
export OPENROUTER_API_KEY='SUA_CHAVE_OPENROUTER_AQUI'      # ai-2 e ai-3 (gpt-oss / Llama 3.3 70B)

# Fallback opcional p/ rodar o ai-3 (Llama 3.3 70B) no Groq, com batching:
#   AI3_BASE_URL=https://api.groq.com/openai/v1 AI3_MODEL=llama-3.3-70b-versatile AI3_API_KEY="$GROQ_API_KEY" ... --batch-size 6
export GROQ_API_KEY='SUA_CHAVE_GROQ_AQUI'                  # opcional (pode listar várias separadas por vírgula)
